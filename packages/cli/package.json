{
  "name": "@atlassian-ai-toolkit/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "atlassian-ai": "src/bin.ts"
  },
  "scripts": {
    "dev": "bun run src/bin.ts",
    "build": "bun build ./src/bin.ts --outdir ./dist --target node",
    "build:binary": "bun build ./src/bin.ts --compile --minify --outfile ./dist/atlassian-ai",
    "build:darwin-arm64": "bun build ./src/bin.ts --compile --minify --target=bun-darwin-arm64 --outfile ./dist/atlassian-ai-darwin-arm64",
    "build:darwin-x64": "bun build ./src/bin.ts --compile --minify --target=bun-darwin-x64 --outfile ./dist/atlassian-ai-darwin-x64",
    "build:linux-arm64": "bun build ./src/bin.ts --compile --minify --target=bun-linux-arm64 --outfile ./dist/atlassian-ai-linux-arm64",
    "build:linux-x64": "bun build ./src/bin.ts --compile --minify --target=bun-linux-x64 --outfile ./dist/atlassian-ai-linux-x64",
    "build:windows-x64": "bun build ./src/bin.ts --compile --minify --target=bun-windows-x64 --outfile ./dist/atlassian-ai-windows-x64.exe",
    "test": "bun test",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@atlassian-ai-toolkit/sdk": "workspace:*",
    "@stricli/core": "^1.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/bun": "latest"
  }
}
